# Anthropic API key
ANTHROPIC_API_KEY=
# GitHub personal access token — the agent uses it to read/manage Issues and to push
# branches and open/merge Pull Requests (PR-based landing, see ADR-0003).
# Create a fine-grained token: https://github.com/settings/personal-access-tokens/new
# Required repository permissions: Issues (Read and write), Pull requests (Read and
# write), Contents (Read and write), and Metadata (Read)
GH_TOKEN=
# LiteLLM API key. The host LiteLLM proxy currently has no master key configured
# (see docs/adr/0002-host-access-via-tailscale-ip.md), so any non-empty placeholder
# works. pi still requires apiKey to be resolvable. The proxy's base URL and the NAME
# of this env var now live in the per-machine Host profile (~/.teahouse/host-profile.json;
# ADR-0014, #109), not in this repo — see .sandcastle/host-profile.example.json.
LITELLM_API_KEY=sk-anything
