{
  // Dedicated typecheck for the Sandcastle AFK workflow. The root tsconfig's
  // `**/*` globs skip dot-directories, so `.sandcastle/` is invisible to
  // `pnpm typecheck` (root `tsc`). This config exists solely to enforce the
  // exhaustiveness guarantees the code relies on (e.g. the `never` guards in
  // events.mts and the EVENT_TYPE_TAGS record). Node/ESM oriented — Sandcastle
  // runs under `tsx`, never through the Next.js bundler. Requires TS >= 5.2 for
  // `await using` (explicit resource management) in main.mts.
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom"],
    "jsx": "react-jsx",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    // Test/source files import siblings by their .mts source specifier; safe
    // because this config only typechecks (noEmit) and never emits JS.
    "allowImportingTsExtensions": true,
    // .tsx/.mts files import sibling modules by their emitted .jsx/.mjs
    // specifiers; allowJs lets the plain-JS render-transcript.mjs resolve too
    // (checkJs off — its types aren't the point of this gate).
    "allowJs": true,
    "checkJs": false,
    "noEmit": true
  },
  "include": ["**/*.mts", "**/*.tsx", "**/*.mjs"],
  "exclude": ["node_modules"]
}
