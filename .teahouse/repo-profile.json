{
  "schemaVersion": 2,
  "installBuild": "pnpm install --frozen-lockfile",
  "verify": {
    "typecheck": "pnpm typecheck",
    "test": "pnpm test"
  },
  "baseBranch": "main",
  "branchPrefix": "teahouse/",
  "poolSize": 4,
  "codingStandardsPath": "@.teahouse/CODING_STANDARDS.md",
  "models": {
    "profiles": {
      "glm": {
        "planner": {
          "model": "litellm/glm-5.2",
          "effort": "high"
        },
        "implementer": {
          "model": "litellm/glm-5.2",
          "effort": "medium"
        },
        "reviewer": {
          "model": "litellm/glm-5.2",
          "effort": "high"
        },
        "resolver": {
          "model": "litellm/glm-5.2",
          "effort": "high"
        }
      },
      "mixed": {
        "planner": {
          "model": "claude-opus-4-8",
          "effort": "high"
        },
        "implementer": {
          "model": "litellm/glm-5.2",
          "effort": "medium"
        },
        "reviewer": {
          "model": "claude-opus-4-8",
          "effort": "high"
        },
        "resolver": {
          "model": "claude-opus-4-8",
          "effort": "high"
        }
      }
    },
    "default": "mixed"
  }
}
