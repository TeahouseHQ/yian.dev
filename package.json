{
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0",
  "scripts": {
    "dev": "next dev -p ${PORT:-3030}",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "build-base": "docker build -t sandcastle-base:latest --build-arg AGENT_UID=$(id -u) --build-arg AGENT_GID=$(id -g) -f node_modules/teahouse/engine/base.Dockerfile node_modules/teahouse/engine",
    "build-image": "pnpm build-base && sandcastle docker build-image",
    "orchestrate": "pnpm build-image && teahouse orchestrate",
    "cockpit": "teahouse cockpit",
    "browse": "teahouse browse",
    "prune-runs": "teahouse prune",
    "prepare": "node scripts/link-git-hooks.js"
  },
  "dependencies": {
    "classnames": "^2.3.1",
    "date-fns": "^2.28.0",
    "feed": "^5.2.1",
    "gray-matter": "^4.0.3",
    "next": "^15.5.18",
    "next-sitemap": "^4.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-format": "^5.0.0",
    "rehype-highlight": "^7.0.0",
    "rehype-react": "^8.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.0",
    "unified": "^11.0.4"
  },
  "optionalDependencies": {
    "teahouse": "git+https://github.com/TeahouseHQ/teahouse.git"
  },
  "pnpm": {
    "overrides": {
      "@types/unist": "^3.0.2"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,mts,cjs,cts,json,css,md,yml,yaml}": "prettier --write"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.12.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "autoprefixer": "^10.4.17",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.2",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.33.2",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.10",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
